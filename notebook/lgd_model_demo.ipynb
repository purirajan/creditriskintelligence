    'loan_amount':            5000.0,
    'origination_ltv':        0.0,
    'months_past_due':        3,
    'secured_flag':           0,
    'product_type_code':      2,
    'time_in_default_months': 2,
    'income_proxy':           45000.0,
    'collection_agency_flag': 0,
    'legal_action_flag':      0,
    'macro_downturn_flag':    0,
}, application_id='APP-001')

print(result['lgd_estimate'])    # TTC LGD
print(result['lgd_downturn'])    # Basel III downturn LGD
